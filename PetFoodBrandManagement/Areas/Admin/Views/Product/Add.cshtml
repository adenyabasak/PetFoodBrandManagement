@model PetFoodBrandManagement.Model.Entities.Product

@{
    ViewData["Title"] = "Yeni Ürün";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="dashboard-title">
    <h1>Yeni Ürün Ekle</h1>
    <p>Mama ürününü marka ve kategori seçerek ekleyebilirsiniz.</p>
</div>

<div class="content-card">

    <form action="/Admin/Product/Add" method="post" enctype="multipart/form-data">

        <div class="form-group">
            <label>Ürün Adı</label>
            <input name="ProductName" class="form-control-custom" />
        </div>

        <div class="form-group">
            <label>Marka</label>
            <select name="BrandId" class="form-control-custom" asp-items="ViewBag.Brands">
                <option value="">Marka seçiniz</option>
            </select>
        </div>

        <div class="form-group">
            <label>Kategori</label>
            <select name="CategoryId" class="form-control-custom" asp-items="ViewBag.Categories">
                <option value="">Kategori seçiniz</option>
            </select>
        </div>

        <div class="form-group">
            <label>Fiyat</label>
            <input name="Price" type="number" step="0.01" class="form-control-custom" />
        </div>

        <div class="form-group">
            <label>Stok</label>
            <input name="Stock" type="number" class="form-control-custom" />
        </div>

        <div class="form-group">
            <label>Açıklama</label>
            <textarea name="Description" class="form-control-custom" rows="4"></textarea>
        </div>

        <div class="form-group">
            <label>Ürün Resmi</label>
            <input type="file" name="imageFile" class="form-control-custom" />
        </div>

        <button type="submit" class="btn-purple">
            <i class="bi bi-check-circle"></i> Kaydet
        </button>

        <a href="/Admin/Product/Index" class="btn-cancel">Vazgeç</a>

    </form>

</div>