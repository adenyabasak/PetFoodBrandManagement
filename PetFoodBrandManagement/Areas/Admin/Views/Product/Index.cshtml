@model IEnumerable<PetFoodBrandManagement.Model.Entities.Product>

@{
    ViewData["Title"] = "Ürünler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="dashboard-title">
    <h1>Ürünler</h1>
    <p>Mama ürünlerini buradan yönetebilirsiniz.</p>
</div>

<div class="content-card">

    <div class="table-header">
        <h3>Ürün Listesi</h3>

        <a href="/Admin/Product/Add" class="btn-purple">
            <i class="bi bi-plus-circle"></i> Yeni Ürün Ekle
        </a>
    </div>

    <table class="custom-table">

        <thead>
            <tr>
                <th>Resim</th>
                <th>Ürün</th>
                <th>Marka</th>
                <th>Kategori</th>
                <th>Fiyat</th>
                <th>Stok</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="table-img" />
                        }
                    </td>

                    <td>@item.ProductName</td>

                    <td>@item.Brand?.BrandName</td>

                    <td>@item.Category?.CategoryName</td>

                    <td>@item.Price ₺</td>

                    <td>@item.Stock</td>

                    <td>
                        @if (item.Status)
                        {
                            <span class="status active">Aktif</span>
                        }
                        else
                        {
                            <span class="status passive">Pasif</span>
                        }
                    </td>

                    <td>

                        <a href="/Admin/Product/Update/@item.ProductId" class="btn-edit">
                            Düzenle
                        </a>

                        <a href="/Admin/Product/Delete/@item.ProductId" class="btn-delete">
                            Sil
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>