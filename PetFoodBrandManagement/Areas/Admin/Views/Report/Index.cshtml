@{
    ViewData["Title"] = "Raporlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .report-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 22px;
    }

    .report-card {
        background: #fff;
        border-radius: 24px;
        padding: 28px;
        min-height: 145px;
        box-shadow: 0 18px 45px rgba(31, 41, 55, 0.08);
        border: 1px solid #e5e7eb;
    }

        .report-card h5 {
            font-size: 15px;
            color: #6b7280;
            margin-bottom: 15px;
        }

        .report-card h2 {
            font-size: 34px;
            font-weight: 700;
            color: #7c3aed;
        }

    .report-buttons {
        margin: 25px 0 30px;
    }

    .btn-purple {
        display: inline-block;
        background: #7c3aed;
        color: white;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: .3s;
        box-shadow: 0 8px 20px rgba(124,58,237,.25);
    }

        .btn-purple:hover {
            background: #6d28d9;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }
</style>

<div class="dashboard-title">
    <h1>Raporlar</h1>
    <p>Sistem genelindeki temel istatistikleri buradan görebilirsiniz.</p>
</div>

<div class="report-buttons">
    <a href="/Admin/Report/ExportExcel" class="btn-purple">
        📊 Excel İndir
    </a>

    <a href="/Admin/Report/ExportPdf" class="btn-purple" style="margin-left:12px;">
        📄 PDF İndir
    </a>
</div>

<div class="report-grid">

    <div class="report-card">
        <h5>Toplam Marka</h5>
        <h2>@ViewBag.BrandCount</h2>
    </div>

    <div class="report-card">
        <h5>Toplam Kategori</h5>
        <h2>@ViewBag.CategoryCount</h2>
    </div>

    <div class="report-card">
        <h5>Toplam Ürün</h5>
        <h2>@ViewBag.ProductCount</h2>
    </div>

    <div class="report-card">
        <h5>Toplam Sipariş</h5>
        <h2>@ViewBag.OrderCount</h2>
    </div>

    <div class="report-card">
        <h5>Toplam Yorum</h5>
        <h2>@ViewBag.ReviewCount</h2>
    </div>

    <div class="report-card">
        <h5>Aktif Ürün</h5>
        <h2>@ViewBag.ActiveProduct</h2>
    </div>

    <div class="report-card">
        <h5>Toplam Stok</h5>
        <h2>@ViewBag.TotalStock</h2>
    </div>

    <div class="report-card">
        <h5>Ortalama Fiyat</h5>
        <h2>@ViewBag.AveragePrice ₺</h2>
    </div>

</div>