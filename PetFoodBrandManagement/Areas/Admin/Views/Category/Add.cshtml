@model PetFoodBrandManagement.Model.Entities.Category

@{
    ViewData["Title"] = "Yeni Kategori";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="dashboard-title">
    <h1>Yeni Kategori Ekle</h1>
    <p>Yeni bir mama kategorisi oluşturabilirsiniz.</p>
</div>

<div class="content-card">

    <form action="/Admin/Category/Add" method="post" enctype="multipart/form-data">

        <div class="form-group">
            <label>Kategori Adı</label>
            <input name="CategoryName" class="form-control-custom" />
        </div>

        <div class="form-group">
            <label>Açıklama</label>
            <textarea name="Description" class="form-control-custom" rows="4"></textarea>
        </div>

        <div class="form-group">
            <label>Resim Seç</label>
            <input type="file" name="imageFile" class="form-control-custom" />
        </div>

        <button type="submit" class="btn-purple">
            <i class="bi bi-check-circle"></i> Kaydet
        </button>

        <a href="/Admin/Category/Index" class="btn-cancel">
            Vazgeç
        </a>

    </form>

</div>