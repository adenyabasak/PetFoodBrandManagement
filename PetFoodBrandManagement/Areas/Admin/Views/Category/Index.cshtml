@model IEnumerable<PetFoodBrandManagement.Model.Entities.Category>

@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="dashboard-title">
    <h1>Kategoriler</h1>
    <p>Mama kategorilerini buradan yönetebilirsiniz.</p>
</div>

<div class="content-card">

    <div class="table-header">
        <h3>Kategori Listesi</h3>

        <a href="/Admin/Category/Add" class="btn-purple">
            <i class="bi bi-plus-circle"></i> Yeni Kategori Ekle
        </a>
    </div>

    <table class="custom-table">

        <thead>
            <tr>
                <th>Resim</th>
                <th>Kategori Adı</th>
                <th>Açıklama</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>

                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="table-img" />
                        }
                        else
                        {
                            <span>Resim Yok</span>
                        }

                    </td>

                    <td>@item.CategoryName</td>

                    <td>@item.Description</td>

                    <td>

                        @if (item.Status)
                        {
                            <span class="status active">Aktif</span>
                        }
                        else
                        {
                            <span class="status passive">Pasif</span>
                        }

                    </td>

                    <td>

                        <a href="/Admin/Category/Update/@item.CategoryId" class="btn-edit">
                            Düzenle
                        </a>

                        <a href="/Admin/Category/Delete/@item.CategoryId" class="btn-delete">
                            Sil
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>