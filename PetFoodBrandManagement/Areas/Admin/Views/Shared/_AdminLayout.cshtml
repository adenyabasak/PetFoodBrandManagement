<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PetFood Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/admin.css" rel="stylesheet" />
</head>

<body>
    <div class="admin-layout">

        <aside class="admin-sidebar">
            <div class="admin-logo">
                <div class="logo-icon">
                    <i class="bi bi-paw-fill"></i>
                </div>
                <div>
                    <h4>PetFood</h4>
                    <span>Brand Management</span>
                </div>
            </div>

            <div class="menu-title">Panel</div>

            <a href="/Admin/Home/Index" class="menu-link">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <div class="menu-title">Yönetim</div>

            <a href="/Admin/Brand/Index" class="menu-link">
                <i class="bi bi-award"></i> Markalar
            </a>

            <a href="/Admin/Category/Index" class="menu-link">
                <i class="bi bi-grid-3x3-gap"></i> Kategoriler
            </a>

            <a href="/Admin/Product/Index" class="menu-link">
                <i class="bi bi-bag-heart"></i> Ürünler
            </a>

            <div class="menu-title">Kullanıcı</div>

            <a href="/Admin/Order/Index" class="menu-link">
                <i class="bi bi-cart-check"></i> Siparişler
            </a>

            <a href="/Admin/Review/Index" class="menu-link">
                <i class="bi bi-chat-heart"></i> Yorumlar
            </a>

            <div class="menu-title">Rapor</div>

            <a href="/Admin/Report/Index" class="menu-link">
                <i class="bi bi-graph-up-arrow"></i> Raporlar
            </a>

            <a href="/Admin/News/Index" class="menu-link">
                <i class="bi bi-newspaper"></i> Haberler
            </a>

            <div class="sidebar-card">
                <i class="bi bi-stars"></i>
                <strong>Premium Panel</strong>
                <span>v1.0</span>
            </div>
        </aside>

        <main class="admin-main">

            <header class="admin-topbar">
                <div>
                    <h5>@ViewData["Title"]</h5>
                    <small>Mama firması yönetim sistemi</small>
                </div>

                <div class="topbar-actions">
                    <div class="search-area">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Arama yap..." />
                    </div>

                    <button class="circle-btn">
                        <i class="bi bi-bell"></i>
                    </button>

                    <div class="admin-profile">
                        <div class="avatar">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div>
                            <strong>Admin</strong>
                            <span>Yönetici</span>
                        </div>
                    </div>
                </div>
            </header>

            <section class="admin-content">
                @RenderBody()
            </section>

        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>