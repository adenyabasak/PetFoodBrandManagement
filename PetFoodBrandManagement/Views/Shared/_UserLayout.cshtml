@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PetFood</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="~/css/user.css" rel="stylesheet" />

    <style>
            body {
                margin: 0;
            }

            main {
                min-height: calc(100vh - 110px);
                padding-top: 110px;
            }
    </style>
</head>

<body>

    <header class="user-navbar">

        <div class="logo">
            <i class="bi bi-paw-fill"></i>

            <div>
                <h3>Pet<span>Food</span></h3>
                <small>Premium Pet Nutrition</small>
            </div>
        </div>

        <nav>
            <a href="/Home/Index">Ana Sayfa</a>
            <a href="/Product/Index">Ürünler</a>
            <a href="/Order/MyOrders">Siparişlerim</a>
            <a href="/Review/MyReviews">Yorumlarım</a>
            <a href="/Home/About">Hakkımızda</a>
            <a href="/Home/Contact">İletişim</a>
            <a href="/Home/Karekod">Karekod</a>
        </nav>

        <div class="user-actions">

            @if (Context.Session.GetString("Role") == "Admin")
            {
                <a href="/Admin/Home/Index" class="admin-panel-btn">
                    <i class="bi bi-speedometer2"></i>
                    <span>Admin Paneli</span>
                </a>
            }

            @if (Context.Session.GetString("UserName") == null)
            {
                <a href="/Account/Login" class="login-pill">
                    <i class="bi bi-person-fill"></i>
                    <span>Giriş Yap</span>
                </a>
            }
            else
            {
                <div class="user-profile-pill">
                    <div class="user-avatar">
                        <i class="bi bi-person-fill"></i>
                    </div>

                    <div class="user-text">
                        <strong>@Context.Session.GetString("FullName")</strong>
                        <small>@Context.Session.GetString("Role")</small>
                    </div>

                    <a href="/Account/Logout" class="logout-btn">
                        <i class="bi bi-box-arrow-right"></i>
                    </a>
                </div>
            }

        </div>

    </header>

    <main>
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)

</body>
</html>