@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <h2>Giriş Yap</h2>

        @if (ViewBag.Error != null)
        {
            <div style="background:#fee2e2;color:#991b1b;padding:12px;border-radius:12px;margin-bottom:18px;">
                @ViewBag.Error
            </div>
        }

        <form action="/Account/Login" method="post">

            <div class="form-group">
                <label>Giriş Türü</label>
                <select name="role" class="form-control-custom">
                    <option value="User">👤 User Girişi</option>
                    <option value="Admin">👑 Admin Girişi</option>
                </select>
            </div>

            <div class="form-group">
                <label>Kullanıcı Adı</label>
                <input name="userName" class="form-control-custom" />
            </div>

            <div class="form-group">
                <label>Şifre</label>
                <input name="password" type="password" class="form-control-custom" />
            </div>

            <button type="submit" class="btn-main">Giriş Yap</button>

            <div style="margin-top:20px;text-align:center;">
                <a href="/Account/Register?role=User"
                   class="btn-outline"
                   style="color:#7c3aed;border-color:#7c3aed;">
                    👤 User Kayıt Ol
                </a>

                <a href="/Account/Register?role=Admin"
                   class="btn-outline"
                   style="margin-left:10px;color:#dc2626;border-color:#dc2626;">
                    👑 Admin Kayıt Ol
                </a>
            </div>

        </form>
    </div>
</div>