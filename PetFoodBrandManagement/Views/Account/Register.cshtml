@model PetFoodBrandManagement.Model.Entities.User

@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = "~/Views/Shared/_UserLayout.cshtml";

    string role = Context.Request.Query["role"];
    if (string.IsNullOrEmpty(role))
    {
        role = "User";
    }
}

<div class="auth-wrapper">
    <div class="auth-card">
        <h2>
            @(role == "Admin" ? "👑 Admin Kayıt Ol" : "👤 User Kayıt Ol")
        </h2>

        <form action="/Account/Register" method="post">

            <input type="hidden" name="role" value="@role" />

            <div class="form-group">
                <label>Ad Soyad</label>
                <input name="FullName" class="form-control-custom" />
            </div>

            <div class="form-group">
                <label>Kullanıcı Adı</label>
                <input name="UserName" class="form-control-custom" />
            </div>

            <div class="form-group">
                <label>E-posta</label>
                <input name="Email" class="form-control-custom" />
            </div>

            <div class="form-group">
                <label>Şifre</label>
                <input name="Password" type="password" class="form-control-custom" />
            </div>

            <button type="submit" class="btn-main">
                @(role == "Admin" ? "Admin Olarak Kayıt Ol" : "User Olarak Kayıt Ol")
            </button>

        </form>
    </div>
</div>